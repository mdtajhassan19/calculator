  "item": [
    {
      "name": "Valid test case",
      "item": [
        {
          "name": "Calculator",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Valid addition expecting 200\", () => {\r",
                  "    console.log(pm.response.code)\r",
                  "    pm.expect([200]).to.include(pm.response.code)\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Verify result \", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.result).to.eql(25.0);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"a\": {{a}},\r\n  \"b\": {{b}},\r\n  \"operation\": \"add\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://127.0.0.1:8000/calculate",
              "protocol": "http",
              "host": [
                "127",
                "0",
                "0",
                "1"
              ],
              "port": "8000",
              "path": [
                "calculate"
              ]
            }
          },
          "response": []
        }
      ]
    },
